      {
        "isStatement": true,
        "hasOrderedList": true,
        "statement": "Your program should take as input:",
        "orderedList": [
          "The money allocated in equity, debt and gold funds.",
          "Monthly SIP payments.",
          "Monthly change rate (loss or growth) for each type of fund."
        ]
      },
      {
        "isStatement": true,
        "hasOrderedList": true,
        "statement": "The output should be",
        "orderedList": [
          "Balanced amount of each fund for a certain month.",
          "Rebalanced amount of each month if applicable."
        ]
      },
      {
        "isStatement": true,
        "hasHeading": true,
        "heading": "Input Commands",
        "statement": "There are 5 input commands defined to separate out the actions. Your input format will start with either of these commands i.e ALLOCATE, SIP, CHANGE, BALANCE, REBALANCE",
        "hasSubStatements": true,
        "subStatements": [
          {
            "subStatementHeading": "ALLOCATE",
            "subStatementHasHeading": true,
            "subStatement": "The ALLOCATE command receives the initial investment amounts for each fund.",
            "subStatementExamples": "Format - ALLOCATE AMOUNT_EQUITY AMOUNT_DEBT AMOUNT_GOLD \n Example- ALLOCATE 6000 3000 1000 means that an amount of 6000, 3000 and 1000 is initially invested in equity, debt and gold fund respectively."
          },
          {
            "subStatementHeading": "SIP",
            "subStatementHasHeading": true,
            "subStatement": "The SIP command receives the investment amount on a monthly basis for each fund.",
            "subStatementExamples": "Format - SIP AMOUNT_EQUITY AMOUNT_DEBT AMOUNT_GOLD \n Example - SIP 2000 1000 500 means a monthly payment of 2000, 1000 and 500 is done against each of equity, debt and gold funds respectivelty."
          },
          {
            "subStatementHeading": "CHANGE",
            "subStatementHasHeading": true,
            "subStatement": "The CHANGE command receives the monthly rate of change (growth or loss) for each fund type. A negative value represents a loss.",
            "subStatementExamples": "Format - CHANGE AMOUNT_EQUITY AMOUNT_DEBT AMOUNT_GOLD MONTH Example - CHANGE 8.00% -3.00% 7.00% APRIL means in the month of April equity received a growth of 8%, debt has taken a loss by 3% and gold received a growth of 7%."
          },
          {
            "subStatementHeading": "BALANCE",
            "subStatementHasHeading": true,
            "subStatement": "The BALANCE command receives a month name.",
            "subStatementExamples": "Format - BALANCE MONTH \n Example - BALANCE APRIL means - print the balance for each fund as on April month."
          },
          {
            "subStatementHeading": "REBALANCE",
            "subStatementHasHeading": true,
            "subStatement": "The REBALANCE command receives no additional inputs.",
            "subStatementExamples": "Input Format - REBALANCE \n Example - REBALANCE - Rebalance happens compulsorily after 6 months in June and December. \n The REBALANCE command shows the last rebalanced amount for each fund at the time of \n rebalancing. If 6 months data is not available then print CANNOT_REBALANCE. \n\n Output format - EQUITY DEBT GOLD \n Example - 10593 7898 2273"
          }
        ]
      },
      {
        "isStatement": true,
        "hasOrderedList": true,
        "hasHeading": true,
        "heading": "Assumptions",
        "statement": null,
        "orderedList": [
          "Balances are always floored to the nearest integers.",
          "The rebalancing happens on 6th (June) and 12th (December) month.",
          "The allocation always happens from January, and SIP from February."
        ]
      }
    ]
