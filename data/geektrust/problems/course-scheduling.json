  "problemStatement": {
    "usesExperimentalComponent": true,
    "contentSections": [
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Context",
        "subSections": [
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": "The head of the Learning management system (LMS) has hired you as a consultant. The LMS team has the goal of upskilling the employees with the latest topics via courses. You need to help build a system to schedule and manage the courses."
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Goal",
        "subSections": [
          {
            "isStatement": true,
            "hasSubsectionHeading": false,
            "statement": "Your job is to build a simple command line application, which does the following:\n",
            "hasNestedList": true,
            "listItems": [
              {
                "text": "Add course offering",
                "children": [
                  {
                    "text": "A course offering has course title, instructor and date."
                  },
                  {
                    "text": "It should also contain a minimum & maximum number of employees for the course offering."
                  }
                ]
              },
              {
                "text": "Register for the course",
                "children": [
                  {
                    "text": " Employees can register for the courses."
                  },
                  {
                    "text": "If no. of employees registered for the course has reached the maximum, the result will be COURSE_FULL_ERROR."
                  },
                  {
                    "text": "Otherwise, result of registration will be ACCEPTED."
                  }
                ]
              },
              {
                "text": "Cancel registration",
                "children": [
                  {
                    "text": "Employees can cancel their registration until the course allotment is completed."
                  }
                ]
              },
              {
                "text": "Course allotment",
                "children": [
                  {
                    "text": "This feature allots employees to course offering, before the course offering date."
                  },
                  {
                    "text": "It should print a list of all the employees with their details along with their final course allotment status (Registration Number, Employee Name, Email, Course Offering ID, Course Name, Instructor, Date, Final Status). The list should be sorted based on the Registration number."
                  },
                  {
                    "text": "If sufficient registrations are not received then the course offering itself gets cancelled."
                  },
                  {
                    "text": "The employees who have registered will get confirmed unless the minimum number of registrations is not received."
                  },
                  {
                    "text": "Even if the course offering gets canceled due to the minimum number of employees not registered, the list should be printed."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Commands",
        "subSections": [
