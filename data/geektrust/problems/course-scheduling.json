          },
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": null,
            "hasOrderedList": true,
            "orderedList": [
              "There are 2 statuses : CANCEL_ACCEPTED, CANCEL_REJECTED",
              "CANCEL_ACCEPTED when the cancellation is successful.",
              "CANCEL_REJECTED when the course is already allotted."
            ]
          }
        ]
