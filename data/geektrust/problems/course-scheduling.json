                      "word": "<course-offering-id>"
                    }
                  ]
                }
              }
            ]
          },
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": "The format of course-offering-id is OFFERING-<COURSE-NAME>-<INSTRUCTOR>\n"
          },
          {
            "isTable": true,
            "hasTableHeading": true,
            "tableHeading": "Register for the course",
