                    ""
                  ],
                  "ten_device": [
                    ""
                  ]
                },
                "data": {
                  "four_device": "Total cost: Rs.50 for 1 month",
                  "ten_device": "Total cost: Rs.100 for 1 month"
                }
              }
            ]
          },
          {
            "isStatement": true,
            "hasSubsectionHeading": true,
            "subSectionHeading": "Renewal Reminder",
            "statement": "Once a user subscribes to a plan, the user needs to be notified 10 days before the plan expires."
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Goal",
        "subSections": [
          {
            "isStatement": true,
            "hasSubsectionHeading": false,
            "statement": "Given a date when the subscription starts, your program should print: \n",
            "hasOrderedList": true,
            "orderedList": [
              "The date on which the reminder should be sent for each subscription category",
              "The total amount for renewal. Renewal amount is the sum of all the subscription plan amount and top up amount."
            ]
          },
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "hasGlobalClass": true,
            "globalClass": [
              "green-bg"
            ],
            "statement": "💡 Pro tip: Aim to get the Readability and Correctness (I/O) badges - your profile can go forward with most companies with those 2 badges. The rest can be improved upon later!"
          }
        ]
      },
      {
        "hasSectionHeading": true,
        "sectionHeading": "Assumptions",
        "isMadeUpOfSubSections": true,
        "subSections": [
          {
            "hasSubsectionHeading": false,
            "hasOrderedList": true,
            "orderedList": [
              "A user can buy only one category of subscription at a time.",
              "By default all plans can only be streamed on one device",
              "A user can buy only one category of top up at a time.",
              "One top up applies to all the subscriptions being bought."
            ]
          }
        ]
      }
    ]
