  "problemStatement": {
    "usesExperimentalComponent": true,
    "contentSections": [
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Context",
        "subSections": [
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": "DoReMi is a streaming app which allows users to listen to music, podcasts and watch videos. They offer different subscription plans for different categories of services. Users can subscribe to any of these plans.",
            "hasOrderedList": true,
            "orderedList": [
              "A user can choose only one plan per category.",
              "All plans, by default, can only be streamed on one device."
            ]
          },
          {
            "isTable": true,
            "hasTableHeading": true,
            "hasTableDescription": false,
            "tableHeading": "Music streaming subscription plans",
            "tableData": [
              {
