      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Top Up",
        "subSections": [
          {
            "isStatement": true,
            "hasSubsectionHeading": false,
            "statement": "DoReMi allows users to add a top up to increase the number of devices that they can stream to for an additional cost.\n",
            "hasOrderedList": true,
            "orderedList": [
              "A user can choose only one top up. ",
              "The subscribed top up is applicable for all subscriptions.",
              "A top up can be added only when a subscription exists.\n"
            ]
          },
          {
            "isTable": true,
            "hasTableHeading": false,
            "hasTableDescription": false,
            "tableData": [
              {
                "isHeaderRow": true,
                "data": {
                  "four_device": "FOUR_DEVICE",
