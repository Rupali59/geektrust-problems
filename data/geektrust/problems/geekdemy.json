  "problemStatement": {
    "usesExperimentalComponent": true,
    "contentSections": [
      {
        "isMadeUpOfSubSections": true,
        "subSections": [
          {
            "isStatement": true,
            "hasHeading": true,
            "heading": "Context",
            "statement": "Geekdemy provides a wide variety of online education programmes. Students can purchase them and enroll in these programmes. Geekdemy offers attractive discounts through their coupons so that students can spend less while purchasing these programmes.\n"
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Programmes",
            "isStatement": true,
            "statement": "There are 3 different categories of online programmes, and the cost is different for each category. A student can purchase any number of programmes at a time.\n",
            "hasOrderedList": true,
            "orderedList": [
              "CERTIFICATION - Rs.3000",
              "DEGREE - Rs. 5000",
              "DIPLOMA - Rs 2500"
            ]
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "subSections": [
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Coupons",
            "isStatement": true,
            "statement": "The discount coupons offered by Geekdemy are based on different criteria. Only one discount coupon can be applied at a time.\n",
            "hasOrderedList": true,
            "orderedList": [
              "B4G1 - This coupon is applied automatically if 4 or more programmes are being purchased. The student gets one programme for free. The lowest priced programme is given for FREE.\n",
              "DEAL_G20 - This coupon can be applied if the purchased programmes value is Rs.10,000/- or above. It provides a 20% discount on the total programme cost. The coupon needs to be applied explicitly to get a discount.\n",
              "DEAL_G5 - This coupon can only be applied if there are a minimum of 2 programmes being purchased. It provides a 5% discount on the total programme cost. The coupon needs to be applied explicitly to get a discount.\n"
            ]
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Enrollment Fee",
            "isStatement": true,
            "statement": "If the total programme cost is below Rs. 6666/, an extra enrollment fee Rs.500/- is added to the cart. The enrollment fee is applied after the discount. If the total programme cost is or above Rs.6666/- the enrollment fee is waived off.\n"
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Pro Membership Fee",
            "isStatement": true,
            "statement": "A student can choose to purchase a Pro Membership for a small amount of Rs.200/- . The pro membership provides an additional membership discount on each of the individual programmes on top of the other discounts.\n",
            "hasOrderedList": true,
            "orderedList": [
              "DIPLOMA - 1% discount",
              "CERTIFICATION - 2% discount",
              "DEGREE - 3% discount\n"
            ]
          },
          {
            "isImage": true,
            "imageClasses": [
              "three-fourth-width",
              "center-align"
            ],
            "imageSource": "https://geektrust.sgp1.cdn.digitaloceanspaces.com/assets/v2/problems/geekdemy/membership_explanation.webp"
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Goal",
        "subSections": [
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": "Build a command-line application to purchase different kinds of programmes from Geekdemy. The application should generate a total bill of the programmes after applying the discounts, if any.\n"
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": " 🛠 Refactoring Goal",
        "hasSectionClass": true,
        "sectionClass": [
          "section-box-shadow"
        ],
        "subSections": [
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": "Turn bad code into good code!\n\nOverall, this solution is not great, is procedural, and does not follow clean code concepts. The input outputs are wrong too!\n\n You can choose to refactor the existing solution or solve this from scratch. You can download the existing coding solution here.\n\nThe existing coding solutions to this problem: "
          },
          {
            "isStatement": false,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "isButtonList": true,
            "buttonList": [
              {
                "iconName": "downloadcd",
