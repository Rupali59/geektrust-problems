  "problemStatement": {
    "usesExperimentalComponent": true,
    "contentSections": [
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Context",
        "subSections": [
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": "A new road has been built and is now open for general traffic. The road construction company needs your help in calculating the money collection via toll from travellers. \n"
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "",
        "subSections": [
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "FASTAG",
            "isStatement": true,
            "statement": "The construction company prefers money to be collected via FASTAG. FASTAG is an electronic payment utility that can be used to pay tolls.  All vehicles have a vehicle number. The FASTAG is associated with a vehicle number.\n If there is no sufficient balance in the FASTAG, then the remaining cost of the toll needs to be paid by cash. If travellers do not have a FASTAG they can make the payment by Cash. There is a flat fee of 40 for such cash transactions.\n"
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Toll charges",
            "isStatement": true,
            "statement": "Amount of toll collected varies based on the weight of the vehicle.\n",
            "isImage": true,
            "imageClasses": [
              "center-align"
            ],
            "imageSource": "https://geektrust.sgp1.cdn.digitaloceanspaces.com/assets/v2/problems/toll-calculation/toll-calculation/vehicle-types.png"
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "\nJourney Type",
            "isStatement": true,
            "statement": "Toll charges are different for a single trip and for a return journey. When a vehicle does a return journey, there is a discount of 50% for the return journey.\nFor eg: If a Van passes through the toll first time, the toll collected is 100. If the same Van passes again through the toll, the amount collected for the return journey is 50. If the Van passes a third time, it will be treated as a new single journey and the toll collected is 100."
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Goal",
        "subSections": [
          {
            "isStatement": true,
            "hasSubsectionHeading": false,
            "statement": "Your task is to build a solution that calculates various tolls collected and print the payment summary and vehicle type summary.\n",
            "hasOrderedList": true,
            "orderedList": [
              "The payment summary should give a breakup of the total amount collected and the total discount given.",
              "The vehicle type summary should display the total number of vehicles passed per type in descending order of the collection amount.\n"
            ]
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Assumptions",
            "isStatement": false,
            "hasOrderedList": true,
            "orderedList": [
              "All vehicles passing through has a vehicle number.",
              "Some vehicles may not have FASTAG, in that case the toll amount is paid by cash.",
              "Some vehicles that have FASTAG may not have sufficient money to pay the toll, then the remaining amount is paid by cash.",
              "Tolls are always collected from FASTAG first, then only cash is taken if needed.",
              "Every cash transaction has a flat fee of 40.",
              "Cash amount collected includes the toll charges paid and the flat fee of 40.",
              "The vehicle count is calculated based on journeys. eg: if the same car passes twice, the count is 2.\n"
            ]
          }
        ]
      }
    ]
  },
