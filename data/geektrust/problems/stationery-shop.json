  "problemStatement": {
    "usesExperimentalComponent": true,
    "contentSections": [
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Context",
        "subSections": [
          {
            "isStatement": true,
            "hasHeading": false,
            "hasSubsectionHeading": false,
            "statement": "College stationery shop is running its annual clearance sale. It is offering steep discounts on a few of the products for this exclusive sale event. They need your help in coming up with a bill calculator.\n"
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Products",
        "subSections": [
          {
            "hasSubSectionHeading": false,
            "isStatement": true,
            "statement": "There are 2 different categories of products. The cost and discount per products are different. \nFollowing products are available for the sale at the shop.\n",
            "isImage": true,
            "imageClasses": [
              "three-fourth-width",
              "center-align"
            ],
            "imageSource": "https://geektrust.sgp1.cdn.digitaloceanspaces.com/assets/v2/problems/stationery-shop/stationery-products.webp"
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Clearance Sale Rules",
            "hasOrderedList": true,
            "orderedList": [
              "For each clothing item, the maximum quantity that can be purchased is 2.",
              "For each stationery item, the maximum quantity that can be purchased is 3.",
              "Discounts can be applied only if the total purchase amount is 1000 rupees or more.",
              "An additional discount of 5% can be applied if the total amount to pay is 3000 rupees or more.",
              "There is a 10% sales tax on total bill. The tax is calculated after all the discounts are applied"
            ]
          }
        ]
      },
      {
        "isMadeUpOfSubSections": true,
        "hasSectionHeading": true,
        "sectionHeading": "Goal",
        "subSections": [
          {
            "isStatement": true,
            "hasSubsectionHeading": false,
            "statement": "Build a command-line application to calculate the total bill amount for the purchase. The application should generate the total bill of the products after applying the discounts, if any and the sales tax. \n",
            "hasOrderedList": true,
            "orderedList": [
              "Program should take each individual product with quantity as input.",
              "Program should print the total amount to pay and total discount applied in a purchase",
              "Program should print an error message if the terms and conditions are not met"
            ]
          },
          {
            "hasSubsectionHeading": true,
            "subSectionHeading": "Assumptions",
            "isStatement": false,
            "hasOrderedList": true,
            "orderedList": [
              "Tax will be applied at the end of bill calculation after the discounts are applied if any.",
              "Keep the decimal precision to 2 decimal places."
            ]
          }
        ]
      }
    ]
  },
